/* Category Page Ajax Handler */
function category_page_ajax_handler(){

    // Option Page Values
    $pdp_see_product_title = get_field( 'pdp_see_product_title','option' );
    $pdp_speed_title = get_field( 'pdp_speed_title','option' );
    $pdp_torque_title = get_field( 'pdp_torque_title','option' );
    $pdp_voltage_title = get_field( 'pdp_voltage_title','option' );
    $pdp_weight_title = get_field( 'pdp_weight_title','option' );
    $pdp_nominal_torque_title = get_field( 'pdp_nominal_torque_title','option' );


    $term_id = isset($_POST['term_id']) ? $_POST['term_id'] : '';
    $posts_per_pages = isset($_POST['posts_per_page']) ? $_POST['posts_per_page'] : -1;
    $paged = isset($_POST['paged']) ? $_POST['paged'] : 1;
    $speed_filter_data = (!empty($_POST['catSpeedMetavalue']) ? $_POST['catSpeedMetavalue'] : [] );
    $torque_filter_data = (!empty($_POST['catTorqueMetaValue']) ? $_POST['catTorqueMetaValue'] : []);
    $voltage_filter_data = (!empty($_POST['catVoltageMetaValue']) ? $_POST['catVoltageMetaValue'] : []);
    $weight_filter_data = (!empty($_POST['catWeightMetaValue']) ? $_POST['catWeightMetaValue'] : []);
    $search_value = isset($_POST['catSearchValue']) ? $_POST['catSearchValue'] : '' ;
    $category_child_term_id = isset($_POST['childCategoryTerm']) ? $_POST['childCategoryTerm'] :'';

    
    $data ='';
    $product_filter_data = '';
    $pagination_data = '';


    // Query args
    $query_args = array(
        'post_type'         => 'product',
        'post_status'       => 'publish',
        'order'             => 'DESC',
        'order_by'          => 'date',
        'posts_per_page'    => $posts_per_pages,
        'paged'             => $paged,
        's'                 => $search_value,
        'tax_query'         => array(
            /*'relation'=>'AND',
            [
                'taxonomy' => 'product-market-sector',
                'field'    => 'slug',
                'terms'    => 'drive-system',
            ],*/
            [
                'taxonomy'  => 'product-category',
                'field'     => 'term_id',
                'terms'     => $term_id,
            ],
        ),
        'meta_query'        => ['relation' => 'AND'],
    );

    if($category_child_term_id){
        $query_args['tax_query'][] = [
            'taxonomy'  => 'product-category',
            'field'     => 'term_id',
            'terms'     => $category_child_term_id,
        ];
    }

    // Speed Filter
    if(!empty($speed_filter_data) && is_array($speed_filter_data)):
        foreach($speed_filter_data as $speed_filter):
            $value = $speed_filter['value'] ? $speed_filter['value'] :'';
            $label = $speed_filter['label'] ? $speed_filter['label'] :'';

            if ($label && preg_match('/^(\d+)\s*-\s*(\d+)$/', $label, $matches)):
                $min_speed = intval($matches[1]);
                $max_speed = intval($matches[2]);

                $query_args['meta_query'][] = [
                    'key'     => 'pd_minimum_speed',
                    'value'   => $min_speed,
                    'compare' => '>=',
                    'type'    => 'NUMERIC',
                ];
                $query_args['meta_query'][] = [
                    'key'       => 'pd_maximum_speed',
                    'value'     => $max_speed,
                    'compare'   => '<=',
                    'type'      => 'NUMERIC',
                ];
                
            endif;

        endforeach;
    endif;

    // Torque Filter
    if(!empty($torque_filter_data) && is_array($torque_filter_data)):
        foreach($torque_filter_data as $torque_filter):
            $value = $torque_filter['value'] ? $torque_filter['value'] :'';
            $label = $torque_filter['label'] ? $torque_filter['label'] :'';

            if ($label && preg_match('/^([\d.]+)\s*-\s*([\d.]+)$/', $label, $matches)):
                $min_torque = floatval($matches[1]);
                $max_torque = floatval($matches[2]);

                $query_args['meta_query'][] = [
                    'key'       => 'pd_torque',
                    'value'     => array($min_torque , $max_torque),
                    'compare'   => 'BETWEEN',
                    'type'      => 'NUMERIC',
                ];

            endif;  
            
        endforeach;
    endif;

    // Voltage Filter
    if(!empty($voltage_filter_data) && is_array($voltage_filter_data)):
        
        foreach($voltage_filter_data as $voltage_filter_value):
            $value = $voltage_filter_value['value'] ? intval($voltage_filter_value['value']) :'';

            $query_args['meta_query'][] = [

                'key' => 'number_index',
                'value' => ',' . $value . ',',
                'compare' => 'LIKE'

            ];

        endforeach;
    endif;

    // Weight Filter
    if(!empty($weight_filter_data) && is_array($weight_filter_data)):
        foreach($weight_filter_data as $weight_filter_value):
            $value = $weight_filter_value['value'] ? $weight_filter_value['value'] :'';
            
            
            if (preg_match('/^<\s*(\d+(\.\d+)?)/', $value, $match)) {
                // Example: <1
                $query_args['meta_query'][] = [
                    'key' => 'pd_weight',
                    'value' => $match[1],
                    'compare' => '<',
                    'type' => 'NUMERIC'
                ];
            }elseif(preg_match('/^>(\s*)(\d+(\.\d+)?)/', $value, $match)){
                $query_args['meta_query'][] = [
                    'key' => 'pd_weight',
                    'value' => $match[2],
                    'compare' => '>',
                    'type' => 'NUMERIC'
                ];
            }elseif(preg_match('/^(\d+(\.\d+)?)\s*-\s*(\d+(\.\d+)?)/', $value, $match)){
                $query_args['meta_query'][] = [
                    'key' => 'pd_weight',
                    'value' => [$match[1], $match[3]],
                    'compare' => 'BETWEEN',
                    'type' => 'NUMERIC'
                ];
            }

        endforeach;
    endif;

    $query = new WP_Query($query_args);

    if($query->have_posts()) :
        while ($query->have_posts()) : $query->the_post();

                $post_id = get_the_ID();
                $post_url = get_the_permalink($post_id);
                $post_title = get_the_title();
                $pd_product_slider_images = get_field( 'pd_product_slider_images');
                $pd_minimum_speed = get_field( 'pd_minimum_speed', $post_id );
                $pd_maximum_speed = get_field( 'pd_maximum_speed', $post_id );
                $pd_torque = get_field( 'pd_torque', $post_id );
                $pd_weight = get_field( 'pd_weight', $post_id );
                $pd_voltage_details = get_field( 'pd_voltage_details', $post_id );
                $pd_minimum_nominal_torque = get_field( 'pd_minimum_nominal_torque', $post_id );
                $pd_maximum_nominal_torque = get_field( 'pd_maximum_nominal_torque', $post_id );
                $product_attributes = wp_get_post_terms($post_id,'product-attribute');

                $product_filter_data .= category_products_listing_ajax_reponse($pd_product_slider_images,$post_url,$post_title,$pd_minimum_speed,$pd_maximum_speed,$pd_torque,$pd_voltage_details,$pd_minimum_nominal_torque,$pd_maximum_nominal_torque,$product_attributes,$pdp_see_product_title,$pdp_speed_title,$pdp_torque_title,$pdp_voltage_title,$pdp_weight_title,$pdp_nominal_torque_title,$pd_weight);

                // $product_filter_data .= $post_title;


        endwhile;
    endif;

    $total_pages = $query->max_num_pages;
    $current_page = max(1, $paged);
    if($total_pages > 1):

        $prev_disabled = ($current_page <= 1) ? 'disabled' : '';
        $next_disabled = ($current_page >= $total_pages) ? 'disabled' : '';

        $prev_page = $current_page - 1;
        $next_page = $current_page + 1;

        $pagination_links = paginate_links(array(
            'total'     => $total_pages,
            'current'   => $current_page,
            'format'    => 'page/%#%',
            'type'      => 'array', // returns an array of links
            'show_all'  => false,
            'mid_size'  => 2,
            'end_size'  => 1,
            'prev_next' => false, // we're handling arrows manually
        ));

        $pagination_data.= '<div class="custom-pagination">';

        // Previous arrow
        $pagination_data.= '<a class="pagination-prev ' . $prev_disabled . '" href="' . ($prev_disabled ? '#' : esc_url(get_pagenum_link($prev_page))) . '">';
        $pagination_data.= '<img src="' . get_stylesheet_directory_uri() . '/assets/images/prev-arrow.svg" alt="Previous">';
        $pagination_data.= '</a>';

        // Number links
        if (is_array($pagination_links)) {
            foreach ($pagination_links as $link) {
                $pagination_data.= '<div class="pagination-number">' . $link . '</div>';
            }
        }

        // Next arrow
        $pagination_data.= '<a class="pagination-next ' . $next_disabled . '" href="' . ($next_disabled ? '#' : esc_url(get_pagenum_link($next_page))) . '">';
        $pagination_data.= '<img src="' . get_stylesheet_directory_uri() . '/assets/images/next-arrow.svg" alt="Next">';
        $pagination_data.= '</a>';

        $pagination_data.= '</div>';

    endif;


    $response_data = [];
    $response_data = [
        'product_data'      => $product_filter_data,
        'pagination_data'   => $pagination_data,
    ];

    echo json_encode($response_data);
    wp_reset_postdata();
    wp_die();
}
add_action('wp_ajax_category_page_ajax_handler', 'category_page_ajax_handler');
add_action('wp_ajax_nopriv_category_page_ajax_handler', 'category_page_ajax_handler');
/* Category Page Ajax Handler */

/* Category Page Ajax Handler Product Listing */
function category_products_listing_ajax_reponse($pd_product_slider_images,$post_url,$post_title,$pd_minimum_speed,$pd_maximum_speed,$pd_torque,$pd_voltage_details,$pd_minimum_nominal_torque,$pd_maximum_nominal_torque,$product_attributes,$pdp_see_product_title,$pdp_speed_title,$pdp_torque_title,$pdp_voltage_title,$pdp_weight_title,$pdp_nominal_torque_title,$pd_weight) {
    ob_start();
    ?>

    <div class="product-row">
        <?php if($pd_product_slider_images): ?>
            <div class="product-image-slider test">
                <div class="swiper product-listing-slider" id="productListingSlider">
                    <div class="swiper-wrapper">
                        <?php foreach( $pd_product_slider_images as $image ): ?>
