/* Washer Tanks Capacity Liter Filter Ajax Handler */
function washer_tanks_liter_filter_ajax_handler(){


    $wsd_washer_tank_system_liters_details = get_field( 'wsd_washer_tank_system_liters_details','options');
    $washer_system_product_liter_suffix_text = get_field( 'washer_system_product_liter_suffix_text','options');
    $wsd_ability_title = get_field( 'wsd_ability_title','options');
    $wsd_type_of_plug_title = get_field( 'wsd_type_of_plug_title','options');
    $wsd_number_of_bombs_title = get_field( 'wsd_number_of_bombs_title','options');
    $wsd_level_sensor_title = get_field( 'wsd_level_sensor_title','options');
    $wsd_more_information_title = get_field( 'wsd_more_information_title','options');
    $pdp_voltage_title = get_field( 'pdp_voltage_title','options');

    $washer_tank_capacity_meta_value = isset($_POST['washerTankLiterMetaValue']) ? floatval($_POST['washerTankLiterMetaValue']) : null;
    $data = '';


    $meta_query_range = [];

    if ($washer_tank_capacity_meta_value !== '') {
        if ($washer_tank_capacity_meta_value == 0) {
            // Entre 0 y 1
            $meta_query_range[] = [
                'key'     => 'espd_ability',
                'value'   => [0, 1],
                'type'    => 'NUMERIC',
                'compare' => 'BETWEEN',
            ];
        } elseif ($washer_tank_capacity_meta_value == 10) {
            // Mayores o iguales a 10
            $meta_query_range[] = [
                'key'     => 'espd_ability',
                'value'   => 10,
                'type'    => 'NUMERIC',
                'compare' => '>=',
            ];
        } else {
            // Entre valor-1 y valor
            $meta_query_range[] = [
                'key'     => 'espd_ability',
                'value'   => [$washer_tank_capacity_meta_value - 1, $washer_tank_capacity_meta_value],
                'type'    => 'NUMERIC',
                'compare' => 'BETWEEN',
            ];
        }
    }

    $query_args = array(
        'post_type'         => 'product',
        'posts_status'      => 'publish',
        'posts_per_page'    => -1,
        'order'             => 'DESC',  
        'order_by'          => 'date',
        'tax_query'         => [ 
            'relation'      => 'AND',
            [
                'taxonomy'  => 'product-line',
                'field'     => 'term_id',
                'terms'     => 122,
            ],
        ],
        'meta_query'        => array_merge([
            'relation' => 'AND',
        ], $meta_query_range),
    );

    /*$query_args = array(
        'post_type'         => 'product',
        'posts_status'      => 'publish',
        'posts_per_page'    => -1,
        'order'             => 'DESC',  
        'order_by'          => 'date',
        'tax_query'         => [ 
            'relation'      => 'AND',
            [
                'taxonomy'  => 'product-line',
                'field'     => 'term_id',
                'terms'     => 122,
            ],
        ],
        'meta_query'        => [
            'relation'=>'AND',
            [
                'key'       => 'espd_ability',
                'value'     => $washer_tank_capacity_meta_value,
                'compare'   => '=',
            ],
        ],
    );*/

    $query = new WP_Query($query_args);

    if($query->have_posts()) :
        while ($query->have_posts()) : $query->the_post();

            $post_id = get_the_ID();
            $post_url = get_the_permalink($post_id);
            $post_title = get_the_title();
            $pd_product_slider_images = get_field( 'pd_product_slider_images',$post_id);
            $pd_voltage_details = get_field( 'pd_voltage_details', $post_id );
            $espd_ability = get_field( 'espd_ability',$post_id );
            $espd_type_of_plug = get_field( 'espd_type_of_plug',$post_id );
            $espd_number_of_bombs = get_field( 'espd_number_of_bombs',$post_id );
            $espd_level_sensor = get_field( 'espd_level_sensor',$post_id );

            $product_attributes = wp_get_post_terms($post_id,'product-attribute');

            $data .= washer_tank_liters_product_listing(
                $post_id,
                $pd_product_slider_images,
                $post_title,
                $product_attributes,
                $espd_level_sensor,
                $espd_number_of_bombs,
                $espd_type_of_plug,
                $espd_ability,
                $pd_voltage_details,
                $wsd_washer_tank_system_liters_details,
                $wsd_ability_title,
                $wsd_type_of_plug_title,
                $wsd_number_of_bombs_title,
                $wsd_level_sensor_title,
                $wsd_more_information_title,
                $pdp_voltage_title,
                $washer_system_product_liter_suffix_text
            );


            // $data .= $post_title;

        endwhile;
        wp_reset_postdata();
    endif;


    $response_data = [];
    $response_data = [
        'product_data' => $data,
    ];

    // echo $washer_tank_capacity_meta_value;

    echo json_encode($response_data);

    wp_die();
}
add_action('wp_ajax_washer_tanks_liter_filter_ajax_handler', 'washer_tanks_liter_filter_ajax_handler');
add_action('wp_ajax_nopriv_washer_tanks_liter_filter_ajax_handler', 'washer_tanks_liter_filter_ajax_handler');
/* Washer Tanks Capacity Liter Filter Ajax Handler */


