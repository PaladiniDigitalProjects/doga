                        <?php endforeach; ?>
                    </div>
                    <div class="swiper-btn-container">
                        <div class="swiper-button-prev p-image-slider-prev">
                            <figure>
                                <img src="/wp-content/themes/doga/assets/images/wiper-slider-prev-arrow.svg" alt="slider-prev-arrow">
                            </figure>
                        </div>
                        <div class="swiper-button-next p-image-slider-next">
                            <figure>
                                <img src="/wp-content/themes/doga/assets/images/wiper-slider-next-arrow.svg" alt="slider-next-arrow">
                            </figure>
                        </div>
                    </div>
                </div>
            </div>
        <?php endif; ?>
        <div class="product-info-card">
            <div class="heading">
                <h4>
                    <a href="<?php echo $post_url; ?>">
                        <?php echo $post_title; ?>
                    </a>
                </h4>
            </div>
            <?php if($pd_maximum_speed || $pd_minimum_speed || $pd_torque || $pd_voltage_details || $pd_weight  || $pd_minimum_nominal_torque || $pd_maximum_nominal_torque): ?>
                <div class="product-info-main">

                    <?php if($pd_minimum_speed || $pd_maximum_speed): ?>
                        <div class="product-detail">

                            <?php if($pdp_speed_title): ?>
                                <div class="title">
                                    <h6>
                                        <?php echo $pdp_speed_title; ?>
                                    </h6>
                                </div>
                            <?php endif; ?>
                            <div class="desc">
                                <?php echo ($pd_minimum_speed) ? apply_filters('the_content',$pd_minimum_speed) : ''; ?>
                                <span>-</span>
                                <?php echo ($pd_maximum_speed) ? apply_filters('the_content',$pd_maximum_speed) : ''; ?>
                            </div>

                        </div>
                    <?php endif;  ?>
                    <?php if($pd_torque): ?>
                        <div class="product-detail">
                            <?php if($pdp_torque_title): ?>
                                <div class="title">
                                    <h6>
                                        <?php echo $pdp_torque_title; ?>
                                    </h6>
                                </div>
                            <?php endif; ?>
                            <div class="desc">
                                <span> < </span>
                                <?php echo apply_filters('the_content',$pd_torque); ?>
                            </div>
                        </div>
                    <?php endif; ?>
                    <?php if(!empty($pd_voltage_details)): ?>
                        <div class="product-detail">

                            <?php if($pdp_voltage_title): ?>
                                <div class="title">
                                    <h6>
                                        <?php echo $pdp_voltage_title; ?>
                                    </h6>
                                </div>
                            <?php endif; ?>
                            <div class="desc voltage-desc">
                                <?php foreach($pd_voltage_details as $voltage_data): ?>
                                    <?php
                                        $voltage = $voltage_data['voltage'];
                                    ?>
                                        <?php echo ($voltage) ? apply_filters('the_content',$voltage) . '<span>/</span>' :  ''; ?>
                                <?php endforeach; ?>
                            </div>

                        </div>
                    <?php endif; ?> 
                    <?php if($pd_weight): ?>
                        <div class="product-detail"> 

                            <?php if($pdp_weight_title): ?>
                                <div class="title">
                                    <h6>
                                        <?php echo $pdp_weight_title; ?>
                                    </h6>
                                </div>
                            <?php endif; ?>
                            <div class="desc">
                                <?php echo apply_filters('the_content',$pd_weight); ?>
                            </div>

                        </div>
                    <?php endif; ?>
                    <?php if($pd_minimum_nominal_torque || $pd_maximum_nominal_torque): ?>
                        <div class="product-detail">

                            <?php if($pdp_nominal_torque_title): ?>
                                <div class="title">
                                    <h6>
                                        <?php echo $pdp_nominal_torque_title;  ?>
                                    </h6>
                                </div>
                            <?php endif; ?>
                            <div class="desc">
                                <?php echo ($pd_minimum_nominal_torque) ? apply_filters('the_content',$pd_minimum_nominal_torque) : ''; ?>
                                <span>-</span>
                                <?php echo ($pd_maximum_nominal_torque) ? apply_filters('the_content',$pd_maximum_nominal_torque) : ''; ?>
                            </div>

                        </div>
                    <?php endif; ?>

                </div>
            <?php endif; ?>
            <?php if(!empty($product_attributes) || $post_url): ?>
                <div class="product-info-footer">
                    <?php if(!empty($product_attributes)): ?>
                        <div class="tags-container">
                            <?php foreach($product_attributes as $product_attribute): ?>
                                <?php
                                    $product_attibute_id = $product_attribute->term_id;
                                    $product_attribute_name = $product_attribute->name;
                                ?>
                                <div class="tag">
                                    <?php echo apply_filters('the_content',$product_attribute_name); ?>
                                </div>
                            <?php endforeach; ?>
                        </div>
                    <?php endif; ?>
                    <?php if($post_url): ?>
                        <div class="btn-container">
                            <div class="see-product-btn">
                                <a href="<?php echo $post_url; ?>">
                                    <?php echo $pdp_see_product_title; ?>
                                </a>
                            </div>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endif; ?>
        </div>
    </div>

    <?php
    return ob_get_clean();
}
/* Category Page Ajax Handler Product Listing */

/* Market Archive Filter Ajax Handler */
function market_archive_filter_ajax_handler() {

    $top_level_parent_term_Id = isset($_POST['topLevelTermID']) ? $_POST['topLevelTermID'] : ''; 
    $second_level_term_id = isset($_POST['secondLevelTermID']) ? $_POST['secondLevelTermID'] : '';
    $second_level_term_data = '';
    $third_level_term_data = '';
    $direct_second_level_terms_data = '';
    $third_level_child_terms_counter = 0;


    // Get Second Level Terms
    if($top_level_parent_term_Id):
        $get_second_level_market_terms =   get_terms(
            array(
                'taxonomy'      => 'market-sector',
                'hide_empty'    => true,
                'parent'        => $top_level_parent_term_Id,
            ),
        );
        if(!empty($get_second_level_market_terms)):
            $second_level_data_counter = 1;
            foreach($get_second_level_market_terms as $second_level_term):
                
                $second_level_term_id = $second_level_term->term_id;
                $second_level_term_name = $second_level_term->name;
                $second_level_term_thumbnail_img = get_field( 'thumbnail_image','market-sector_'. $second_level_term_id );

                $second_level_term_data .= second_level_market_terms($second_level_term_id,$second_level_term_thumbnail_img,$second_level_term_name,$second_level_data_counter);
            
                $third_lvl_child_terms = get_terms(
                    array(
                        'taxonomy'      => 'market-sector',
                        'hide_empty'    => false,
                        'parent'        => $second_level_term_id,
                    ),
                );

                if(!empty($third_lvl_child_terms)):
                    $third_level_child_terms_counter++;
                endif;
                
                $second_level_data_counter++;
            endforeach;
        endif;
    endif;

    // Get Third Leven Terms
    if($second_level_term_id):
        $get_third_level_child_terms = get_terms(
            array(
                'taxonomy'      => 'market-sector',
                'hide_empty'    => false,
                'parent'        => $second_level_term_id,
            ),
        );
        if(!empty($get_third_level_child_terms)){
            foreach($get_third_level_child_terms as $third_level_term):

                $third_level_term_id = $third_level_term->term_id;
                $third_level_term_name = $third_level_term->name;
                $third_level_term_thumbnail_img = get_field( 'thumbnail_image','market-sector_'. $third_level_term_id );
                $icon = get_field( 'icon','market-sector_'. $third_level_term_id  );

                $third_level_term_data .= third_level_market_terms($third_level_term_id,$third_level_term_name,$third_level_term_thumbnail_img,$icon);

            endforeach;
        }
    endif;

    // Direct Second Level Terms With Products
    if($third_level_child_terms_counter == 0):
        foreach($get_second_level_market_terms as $second_level_terms):
            $second_level_term_id = $second_level_terms->term_id;
            $second_level_term_name = $second_level_terms->name;
            $second_level_term_thumbnail_img = get_field( 'thumbnail_image','market-sector_'. $second_level_term_id );
            $icon = get_field( 'icon','market-sector_'. $second_level_term_id  );

            // $direct_second_level_terms_data .= $second_level_term_name;
            $direct_second_level_terms_data .= direct_second_level_posts_with_products($second_level_term_id,$second_level_term_name,$second_level_term_thumbnail_img,$icon);

        endforeach;
    endif;
    
    $response_data = [
        'second_level_term_data'        => $second_level_term_data,
        'second_level_different_layout' => $direct_second_level_terms_data,
        'third_level_term_data'         => $third_level_term_data,
        'child_terms_counter'           => $third_level_child_terms_counter,
    ];

    echo json_encode($response_data);

    wp_reset_postdata();
    wp_die();
}
add_action('wp_ajax_market_archive_filter_ajax_handler', 'market_archive_filter_ajax_handler');
add_action('wp_ajax_nopriv_market_archive_filter_ajax_handler', 'market_archive_filter_ajax_handler');
/* Market Archive Filter Ajax Handler */

/* Second Level Market Terms */
function second_level_market_terms($second_level_term_id,$second_level_term_thumbnail_img,$second_level_term_name,$second_level_data_counter){
    ob_start();
    $default_img = get_stylesheet_directory_uri().'/assets/images/product-line-default-img.png';
    ?>
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3 second-level-market-archive-card">
            <a href="javascript:void;" class="ds-market-filter-card <?php echo ($second_level_data_counter == 1) ? 'active-level-2-card' : ''; ?>" data-term-id="<?php echo $second_level_term_id; ?>" >
                <div class="market-card-bg"
                    style="background:url('<?php echo ($second_level_term_thumbnail_img) ? $second_level_term_thumbnail_img['url'] : $default_img; ?>') no-repeat center; background-size: cover">
                </div>
                <div class="title">
                    <p>
                        <?php echo $second_level_term_name; ?>
                    </p>
                </div>
            </a>
        </div>
    <?php
    return ob_get_clean();
}
/* Second Level Market Terms */

/* Third Level Market Terms  */
function third_level_market_terms($third_level_term_id,$third_level_term_name,$third_level_term_thumbnail_img,$icon){
    ob_start();
    $default_img = get_stylesheet_directory_uri().'/assets/images/product-line-default-img.png';
    $product_default_img = get_stylesheet_directory_uri().'/assets/images/product-default-img.jpg';

    $more_information_button = get_field( 'more_information_button','options' );

    $query_args = array(
        'post_type'         => 'product',
        'post_status'       => 'publish',
        'order'             => 'DESC',
        'order_by'          => 'date',
        'posts_per_page'    => -1,
        'tax_query'         => [
            /*'relation'  => 'AND',
            [
                'taxonomy'  => 'product-market-sector',
                'field'     => 'slug',
                'terms'     => 'drive-system',
            ],*/
            [
                'taxonomy'  => 'market-sector',
                'field'     => 'term_id',
                'terms'     => $third_level_term_id,
            ],
        ],
    );

    $query = new WP_Query($query_args);
    if($query->have_posts()):
    ?>
        <div class="ds-market-products-block">
            <div class="heading" data-term-id="<?php echo $third_level_term_id; ?>">
                <?php if($icon || $default_img): ?>
                    <div class="heading-image">
                        <figure>
                            <img src="<?php echo ($icon) ? $icon['url'] : $default_img; ?>"
                                alt="precision-seed-planter">
                        </figure>
                    </div>
                <?php endif; ?>
                <div class="title">
                    <p>
                        <?php echo $third_level_term_name; ?>
                    </p>
                </div>
            </div>
            <div class="common-product-card-content">
                <div class="row">
                    <?php while($query->have_posts()): ?>
                        <?php
                            $query->the_post();
                            $post_id = get_the_ID();
                            $post_title = get_the_title();
                            $post_thumbnail_image = (has_post_thumbnail()) ? get_the_post_thumbnail_url($post_id) : $product_default_img ;
                            $pd_product_short_description = get_field( 'pd_product_short_description');                           
                        ?>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                            <div class="common-product-card">
                                <?php if($post_thumbnail_image): ?>
                                    <div class="image-content">
                                        <div class="img-container">
                                            <figure>
                                                <img src="<?php echo $post_thumbnail_image; ?>" alt="<?php echo $post_title; ?>">
                                            </figure>
                                        </div>
                                    </div>
                                <?php endif; ?>
                                <div class="text-content">
                                    <div class="product-detail">
                                        <div class="product-name">
                                            <h6>
                                                <?php echo $post_title; ?>
                                            </h6>
                                        </div>
                                        <?php if($pd_product_short_description): ?>
                                            <div class="detail">
                                                <div class="desc descriptoin">
                                                    <?php echo $pd_product_short_description; ?>
                                                </div>
                                            </div>
                                        <?php endif; ?>
                                    </div>
                                    <div class="btn-container">
                                        <a href="<?php echo $more_information_button['url']; ?>" class="more-info-btn">
                                            <?php echo $more_information_button['title']; ?>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <?php endwhile; ?>
                </div>
            </div>
        </div>
    <?php
    endif;
    wp_reset_postdata();
    return ob_get_clean();
}
/* Third Level Market Terms  */

/* Direct Second Level Terms With Its Products */
function direct_second_level_posts_with_products($second_level_term_id,$second_level_term_name,$second_level_term_thumbnail_img,$icon) {
    ob_start();
    $default_img = get_stylesheet_directory_uri().'/assets/images/product-line-default-img.png';
    $product_default_img = get_stylesheet_directory_uri().'/assets/images/product-default-img.jpg';

    $more_information_button = get_field( 'more_information_button','options' );

    $query_args = array(
        'post_type'         => 'product',
        'post_status'       => 'publish',
        'order'             => 'DESC',
        'order_by'          => 'date',
        'posts_per_page'    => -1,
        'tax_query'         => [
            /*'relation'  => 'AND',
            [
                'taxonomy'  => 'product-market-sector',
                'field'     => 'slug',
                'terms'     => 'drive-system',
            ],*/
            [
                'taxonomy'  => 'market-sector',
                'field'     => 'term_id',
                'terms'     => $second_level_term_id,
            ],
        ],
    );

    $query = new WP_Query( $query_args );

    if ( $query->have_posts() ) :
    ?>
        <div class="ds-market-products-block">
            <div class="heading">
                <div class="heading-image">
                    <figure>
                        <img src="<?php echo ($icon) ? $icon['url'] : $default_img; ?>"
                            alt="precision-seed-planter">
                    </figure>
                </div>
                <div class="title">
                    <p>
						<?php echo mb_strtoupper($second_level_term_name); ?>
                    </p>
                </div>
            </div>
            <div class="common-product-card-content">
                <div class="row">
                    <?php while($query->have_posts()) : $query->the_post(); ?>
                        <?php
                            $post_id = get_the_ID();
                            $post_title = get_the_title();
                            $post_thumbnail_image = (has_post_thumbnail()) ? get_the_post_thumbnail_url($post_id) : $product_default_img ;
                            $pd_product_short_description = get_field( 'pd_product_short_description'); 
                        ?>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                            <div class="common-product-card">
                                
                                <?php if($post_thumbnail_image): ?>
                                    <div class="image-content">
                                        <div class="img-container">
                                            <figure>
                                                <img src="<?php echo $post_thumbnail_image; ?>" alt="<?php echo $post_title; ?>">
                                            </figure>
                                        </div>
                                    </div>
                                <?php endif; ?>
                                <div class="text-content">
                                    <div class="product-detail">
                                        <div class="product-name">
                                            <h6>
                                                <?php echo $post_title; ?>
                                            </h6>
                                        </div>
                                        <?php if($pd_product_short_description): ?>
                                            <div class="detail">
                                                <div class="desc descriptoin">
                                                    <?php echo $pd_product_short_description; ?>
                                                </div>
                                            </div>
                                        <?php endif; ?>
                                    </div>
                                    <?php if($more_information_button): ?>
                                        <div class="btn-container">
                                            <a href="<?php echo $more_information_button['url']; ?>" class="more-info-btn">
                                                <?php echo $more_information_button['title']; ?>
                                            </a>
                                        </div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                    <?php endwhile; ?>
                </div>
            </div>

        <div>
    <?php
    wp_reset_postdata();
    endif;
    return ob_get_clean();
}
